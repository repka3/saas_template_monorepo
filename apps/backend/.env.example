PORT=3005
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_template
BETTER_AUTH_SECRET=change-me-with-a-32-character-secret
BETTER_AUTH_URL=http://localhost:3005
CORS_ORIGIN=http://localhost:5173
# Set to "false" to disable proxy trust, or a positive integer hop count.
TRUST_PROXY=1
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SaaS Template <no-reply@example.test>
SUPERADMIN_EMAIL=owner@example.com
SUPERADMIN_PASSWORD=change-me-bootstrap-password
SUPERADMIN_NAME=Bootstrap Superadmin
LOG_LEVEL=info
