{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "check-types": "pnpm prisma:generate && tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:studio": "prisma studio --config prisma.config.ts",
    "seed:superadmin": "tsx src/scripts/seed-superadmin.ts"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^7.0.3",
    "@types/node": "^25.5.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "prisma": "^7.7.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@repo/contracts": "workspace:*",
    "better-auth": "^1.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "5",
    "helmet": "^8.1.0",
    "nodemailer": "^7.0.9",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  }
}
